# %% [markdown]
# # Soccer AI Betting – Performance Analysis
# 
# Load prediction logs and evaluate accuracy.

# %%
import pandas as pd
import sqlite3
import matplotlib.pyplot as plt
import seaborn as sns

# %%
conn = sqlite3.connect("../data/betting.db")
predictions = pd.read_sql_query("SELECT * FROM predictions", conn)
results = pd.read_sql_query("SELECT * FROM fixture_results", conn)

# %%
# Merge predictions with actual results
merged = pd.merge(predictions, results, left_on="fixture_id", right_on="fixture_id", how="left")

# %%
# Accuracy per market
accuracy = merged.groupby("market").apply(
    lambda x: (x["actual_outcome"] == 1).mean() if len(x) > 0 else 0
)
print("Accuracy per market:\n", accuracy)

# %%
# Plot profit over time (requires 'profit' column)
if "profit" in merged.columns:
    merged["prediction_date"] = pd.to_datetime(merged["prediction_time"])
    daily_profit = merged.groupby(merged["prediction_date"].dt.date)["profit"].sum().cumsum()
    daily_profit.plot(title="Cumulative Profit", figsize=(10,5))
    plt.show()
